# Frontend Environment Configuration

# Backend API base URL
VITE_API_BASE=http://localhost:8000/api/v1

# MapLibre style URL (optional, for custom map styles)
# VITE_MAP_STYLE=

# Map tiles (comma-separated). If OSM is blocked in your network,
# replace with your internal/publicly reachable tile service.
VITE_MAP_TILES=https://tile.openstreetmap.org/{z}/{x}/{y}.png

# Application title
VITE_APP_TITLE=Harbin Traffic Analytics
